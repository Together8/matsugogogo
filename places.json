
:root{
  --bg:#f7f2e8; --card:#fffdf8; --ink:#253238; --muted:#6a7378;
  --main:#2f6f73; --soft:#a3d5dc; --sand:#e3d5c9; --accent:#e0a458;
  --shadow:0 10px 25px rgba(38,50,56,.10);
}
*{box-sizing:border-box}
body{margin:0;font-family:"Microsoft JhengHei","Noto Sans TC",Arial,sans-serif;background:var(--bg);color:var(--ink);line-height:1.65}
a{color:inherit}
.appbar{position:sticky;top:0;z-index:50;background:rgba(255,253,248,.92);backdrop-filter:blur(10px);box-shadow:0 2px 18px rgba(0,0,0,.06)}
.nav{max-width:1100px;margin:auto;padding:10px 14px;display:flex;align-items:center;gap:10px;overflow-x:auto}
.brand{font-weight:900;color:var(--main);white-space:nowrap;margin-right:auto}
.nav a{white-space:nowrap;text-decoration:none;padding:8px 12px;border-radius:999px;background:#f0e9dc;font-weight:700;font-size:14px}
.nav a.active,.nav a:hover{background:var(--main);color:white}
.hero{min-height:330px;color:white;display:flex;align-items:end;background:linear-gradient(rgba(0,0,0,.2),rgba(0,0,0,.55)),url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");background-size:cover;background-position:center}
.hero-inner{max-width:1100px;margin:auto;padding:60px 18px 34px;width:100%}
.pill{display:inline-block;padding:6px 14px;border:1px solid rgba(255,255,255,.85);border-radius:999px;font-weight:700;margin-bottom:12px}
h1{font-size:clamp(34px,7vw,68px);line-height:1.05;margin:0 0 12px}
.container{max-width:1100px;margin:auto;padding:22px 16px 92px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px;margin:20px 0}
.card{background:var(--card);border-radius:22px;padding:18px;box-shadow:var(--shadow)}
.card h2,.card h3{margin-top:0;color:var(--main)}
.big-buttons{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px}
.bigbtn{display:block;text-decoration:none;background:var(--main);color:white;padding:16px;border-radius:18px;font-weight:900;text-align:center;box-shadow:var(--shadow)}
.section-title{font-size:26px;color:var(--main);border-left:8px solid var(--soft);padding-left:12px;margin:34px 0 16px}
.timeline{display:flex;flex-direction:column;gap:14px}
.time-card{display:grid;grid-template-columns:78px 1fr;gap:14px;background:var(--card);border-radius:20px;padding:16px;border-left:7px solid var(--soft);box-shadow:var(--shadow)}
.time-card time{font-weight:900;color:var(--main)}
.time-card h3{margin:0 0 6px}
.time-card p{margin:0;color:var(--muted)}
.actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.btn{border:0;border-radius:999px;padding:9px 13px;text-decoration:none;background:#eaf2f3;color:#1f4d51;font-weight:900;cursor:pointer;display:inline-flex;gap:6px;align-items:center}
.btn.primary{background:var(--main);color:white}
.btn.warn{background:#fff0d7;color:#7a4b00}
.place-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}
.place-card{overflow:hidden;background:var(--card);border-radius:22px;box-shadow:var(--shadow)}
.place-card img{width:100%;height:155px;object-fit:cover;display:block}
.place-body{padding:16px}
.meta{font-size:14px;color:var(--muted)}
.notice{background:#fff8e8;border-left:7px solid var(--accent);border-radius:16px;padding:14px;margin:14px 0}
input,select{width:100%;padding:12px;border-radius:14px;border:1px solid #ddd;background:white;font-size:16px}
label{font-weight:900;color:var(--main);display:block;margin:10px 0 6px}
.budget-row{display:grid;grid-template-columns:1.4fr .8fr 45px;gap:8px;margin-bottom:8px}
.total{font-size:28px;font-weight:900;color:var(--main)}
.check-item{display:flex;align-items:center;gap:10px;background:var(--card);padding:13px;border-radius:16px;margin-bottom:8px;box-shadow:0 4px 12px rgba(0,0,0,.06)}
.check-item input{width:auto;transform:scale(1.25)}
.progress{height:14px;background:#eee;border-radius:999px;overflow:hidden}
.progress span{display:block;height:100%;background:var(--main);width:0}
.footer-nav{position:fixed;bottom:0;left:0;right:0;background:rgba(255,253,248,.94);backdrop-filter:blur(8px);box-shadow:0 -2px 20px rgba(0,0,0,.08);display:none;z-index:99}
.footer-nav a{flex:1;text-align:center;text-decoration:none;padding:10px 4px;font-size:12px;font-weight:900;color:var(--main)}
@media(max-width:720px){
  .nav a{display:none}.brand{margin:auto}.hero{min-height:280px}
  .time-card{grid-template-columns:1fr}.footer-nav{display:flex}
  .container{padding-bottom:90px}.budget-row{grid-template-columns:1fr 95px 40px}
}
